# Copie para .env e ajuste o caminho da pasta que contém o Player.log no host.
# Windows (caminho com espaços funciona sem aspas no .env do Docker Compose):
MTGA_LOG_DIR=C:\Users\SEU_USUARIO\AppData\LocalLow\Wizards Of The Coast\MTGA

# Token de API da sua conta no mtg-collection-manager (necessário desde a
# versão multi-usuário — sem ele, o tracker detecta partidas mas não
# consegue registrá-las). Gere com (estando logado, troque SEU_TOKEN_DE_SESSAO
# pelo token retornado por /api/auth/login e SUA_SENHA pela sua senha real):
#
#   curl -X POST http://localhost:3001/api/auth/api-token \
#     -H "Authorization: Bearer SEU_TOKEN_DE_SESSAO" \
#     -H "Content-Type: application/json" \
#     -d '{"password":"SUA_SENHA"}'
#
# Cole o token retornado (campo "token") abaixo:
API_TOKEN=
